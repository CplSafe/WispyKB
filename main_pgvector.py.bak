# ==================== MCP (Model Context Protocol) 动态配置 API ====================

class MCPRequest(BaseModel):
    """MCP JSON-RPC 请求模型"""
    jsonrpc: str = "2.0"
    id: Optional[Union[str, int]] = None
    method: str
    params: Optional[Dict[str, Any]] = None


class MCPConfigRequest(BaseModel):
    """MCP 服务器配置请求"""
    name: str
    connection_type: str = "http"  # 'http', 'ws', 'sse', 'stdio'
    url: Optional[str] = None      # HTTP/SSE/WS 模式需要
    command: Optional[str] = None  # stdio 模式需要
    args: Optional[List[str]] = None  # stdio 模式的命令参数
    headers: Optional[Dict[str, str]] = None
    auth_token: Optional[str] = None
    api_key: Optional[str] = None


class MCPTestRequest(BaseModel):
    """MCP 连接测试请求"""
    url: Optional[str] = None      # HTTP 测试
    command: Optional[str] = None  # stdio 测试
    args: Optional[List[str]] = None
    auth_token: Optional[str] = None
    api_key: Optional[str] = None


@app.get("/api/v1/mcp/tools")
async def list_mcp_tools(
    include_remote: bool = True,
    user: Dict = Depends(get_current_user)
):
    """列出所有 MCP 工具（本地 + 远程）"""
    if not mcp_server:
        raise HTTPException(status_code=500, detail="MCP 服务未初始化")

    tools = await mcp_server.get_all_tools()
    return {'tools': tools, 'count': len(tools)}


@app.post("/api/v1/mcp/tools/{tool_name}/invoke")
async def invoke_mcp_tool(
    tool_name: str,
    arguments: Dict[str, Any],
    source: Optional[str] = None,
    user: Dict = Depends(get_current_user)
):
    """调用 MCP 工具"""
    if not mcp_server:
        raise HTTPException(status_code=500, detail="MCP 服务未初始化")

    result = await mcp_server.call_tool(tool_name, arguments, source)

    if 'error' in result:
        raise HTTPException(status_code=400, detail=result['error'])

    return result


@app.get("/api/v1/mcp/configs")
async def list_mcp_configs(user: Dict = Depends(get_current_user)):
    """获取所有 MCP 服务器配置"""
    if not mcp_server:
        raise HTTPException(status_code=500, detail="MCP 服务未初始化")

    configs = await mcp_server.get_remote_configs()
    return {'configs': configs, 'count': len(configs)}


@app.post("/api/v1/mcp/configs")
async def create_mcp_config(
    config: MCPConfigRequest,
    user: Dict = Depends(get_current_user)
):
    """添加新的 MCP 服务器配置（支持本地和远程）"""
    if not mcp_server:
        raise HTTPException(status_code=500, detail="MCP 服务未初始化")

    # 验证参数
    if config.connection_type != 'stdio' and not config.url:
        raise HTTPException(status_code=400, detail="HTTP/SSE/WS 模式需要提供 URL")

    if config.connection_type == 'stdio' and not config.command:
        raise HTTPException(status_code=400, detail="stdio 模式需要提供 command")

    user_id = user.get('user_id') if user else None
    config_id = str(uuid.uuid4())

    try:
        result = await mcp_server.add_remote_server(
            config_id=config_id,
            name=config.name,
            connection_type=config.connection_type,
            url=config.url or "",
            command=config.command,
            args=config.args,
            headers=config.headers,
            auth_token=config.auth_token,
            api_key=config.api_key
        )

        return {
            'id': config_id,
            'message': 'MCP 服务器添加成功',
            **result
        }
    except Exception as e:
        raise HTTPException(status_code=400, detail=f"添加失败: {str(e)}")


@app.delete("/api/v1/mcp/configs/{config_id}")
async def delete_mcp_config(
    config_id: str,
    user: Dict = Depends(get_current_user)
):
    """删除 MCP 服务器配置"""
    if not mcp_server:
        raise HTTPException(status_code=500, detail="MCP 服务未初始化")

    await mcp_server.remove_remote_server(config_id)
    return {'message': 'MCP 服务器已删除'}


# ==================== 向量存储 API ====================

@app.get("/api/v1/vector-store/info")
async def get_vector_store_info(user: Dict = Depends(get_current_user)):
    """获取向量存储信息"""
    if not vector_store_instance:
        return {
            'type': VECTOR_STORE_TYPE,
            'status': 'not_initialized',
            'message': '向量存储未初始化'
        }

    try:
        info = await vector_store_instance.get_info()
        info['status'] = 'active'
        return info
    except Exception as e:
        return {
            'type': VECTOR_STORE_TYPE,
            'status': 'error',
            'error': str(e)
        }


@app.get("/api/v1/vector-store/stats")
async def get_vector_store_stats(user: Dict = Depends(get_current_user)):
    """获取向量存储统计信息"""
    stats = {
        'type': VECTOR_STORE_TYPE,
        'collections': [],
        'total_vectors': 0,
    }

    try:
        if VECTOR_STORE_TYPE == 'milvus' and vector_store_instance:
            from pymilvus import MilvusClient
            client = MilvusClient(uri=MILVUS_CONFIG['uri'])
            stats['total_vectors'] = 0

            # 获取所有集合及其统计
            collections = client.list_collections()
            for coll in collections:
                coll_info = client.get_collection_stats(collection_name=coll)
                stats['collections'].append({
                    'name': coll,
                    'count': int(coll_info.get('row_count', 0)),
                    'dimension': coll_info.get('dimension', 768),
                })
                stats['total_vectors'] += int(coll_info.get('row_count', 0))

        elif VECTOR_STORE_TYPE == 'pgvector':
            # pgvector 统计
            async with pool.connection() as conn:
                async with conn.cursor(row_factory=dict_row) as cur:
                    # 知识库文档统计
                    await cur.execute("""
                        SELECT kb.id, kb.name,
                               (SELECT COUNT(*) FROM documents d WHERE d.kb_id = kb.id) as doc_count,
                               (SELECT COUNT(*) FROM chunks c JOIN documents d ON c.doc_id = d.id WHERE d.kb_id = kb.id) as chunk_count
                        FROM knowledge_bases kb
                        ORDER BY kb.created_at DESC
                    """)
                    kb_stats = await cur.fetchall()

                    total_chunks = 0
                    for kb in kb_stats:
                        stats['collections'].append({
                            'name': kb['name'],
                            'id': kb['id'],
                            'count': kb['chunk_count'] or 0,
                            'doc_count': kb['doc_count'] or 0,
                        })
                        total_chunks += kb['chunk_count'] or 0

                    stats['total_vectors'] = total_chunks

        stats['status'] = 'active'
        return stats

    except Exception as e:
        logger.error(f"获取向量存储统计失败: {e}")
        stats['status'] = 'error'
        stats['error'] = str(e)
        return stats


