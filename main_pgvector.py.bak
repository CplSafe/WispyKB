        async with conn.cursor(row_factory=dict_row) as cur:
            await cur.execute("""
                SELECT id, name, code, status
                FROM system_role
                WHERE deleted_at IS NULL AND status = 0
                ORDER BY sort
            """)
            roles = await cur.fetchall()

    return {"roles": roles}


@app.get("/api/v1/system/roles/{role_id}")
async def get_role(role_id: str, user: Dict = Depends(get_current_user)):
    """获取角色详情"""
    if not user:
        raise HTTPException(status_code=401, detail="未登录")

    if not await has_permission(user['user_id'], 'system:role:manage'):
        raise HTTPException(status_code=403, detail="无权限访问")

    async with pool.connection() as conn:
        async with conn.cursor(row_factory=dict_row) as cur:
            await cur.execute("""
                SELECT * FROM system_role WHERE id = %s AND deleted_at IS NULL
            """, (role_id,))
            role = await cur.fetchone()

            if not role:
                raise HTTPException(status_code=404, detail="角色不存在")

            # 获取角色的菜单权限
            await cur.execute("""
                SELECT menu_id FROM system_role_menu WHERE role_id = %s
            """, (role_id,))
            role['menu_ids'] = [row[0] for row in await cur.fetchall()]

            # 获取角色的数据权限部门
            await cur.execute("""
                SELECT dept_id FROM system_role_data_scope_dept WHERE role_id = %s
            """, (role_id,))
            role['data_scope_dept_ids'] = [row[0] for row in await cur.fetchall()]

    return role


@app.post("/api/v1/system/roles")
async def create_role(request: CreateRoleRequest, user: Dict = Depends(get_current_user)):
    """创建角色"""
    if not user:
        raise HTTPException(status_code=401, detail="未登录")

    if not await has_permission(user['user_id'], 'system:role:create'):
        raise HTTPException(status_code=403, detail="无权限创建角色")

    async with pool.connection() as conn:
        async with conn.cursor() as cur:
            # 检查角色代码是否已存在
            await cur.execute("SELECT id FROM system_role WHERE code = %s AND deleted_at IS NULL", (request.code,))
            if await cur.fetchone():
                raise HTTPException(status_code=400, detail="角色代码已存在")

            role_id = str(uuid.uuid4())
            await cur.execute("""
                INSERT INTO system_role (id, name, code, sort, status, data_scope, remark, created_at)
                VALUES (%s, %s, %s, %s, %s, %s, %s, NOW())
            """, (role_id, request.name, request.code, request.sort, request.status,
                  request.data_scope, request.remark))

            # 分配菜单权限
            if request.menu_ids:
                for menu_id in request.menu_ids:
                    await cur.execute("""
                        INSERT INTO system_role_menu (role_id, menu_id)
                        VALUES (%s, %s)
                        ON CONFLICT (role_id, menu_id) DO NOTHING
                    """, (role_id, menu_id))

            await conn.commit()

    return {"id": role_id, "message": "角色创建成功"}


@app.put("/api/v1/system/roles/{role_id}")
async def update_role(
    role_id: str,
    request: UpdateRoleRequest,
    current_user: Dict = Depends(get_current_user)
):
    """更新角色"""
    if not current_user:
        raise HTTPException(status_code=401, detail="未登录")

    if not await has_permission(current_user['user_id'], 'system:role:update'):
        raise HTTPException(status_code=403, detail="无权限更新角色")

    async with pool.connection() as conn:
        async with conn.cursor() as cur:
            await cur.execute("SELECT * FROM system_role WHERE id = %s AND deleted_at IS NULL", (role_id,))
            role = await cur.fetchone()
            if not role:
                raise HTTPException(status_code=404, detail="角色不存在")

            # 系统内置角色不能修改
            if role[7] == 1:  # type = 1 表示系统内置
                raise HTTPException(status_code=400, detail="系统内置角色不能修改")

            updates = []
            values = []

            if request.name is not None:
                updates.append("name = %s")
                values.append(request.name)
            if request.sort is not None:
                updates.append("sort = %s")
                values.append(request.sort)
            if request.status is not None:
                updates.append("status = %s")
                values.append(request.status)
            if request.data_scope is not None:
                updates.append("data_scope = %s")
                values.append(request.data_scope)
            if request.remark is not None:
                updates.append("remark = %s")
                values.append(request.remark)

            if updates:
                values.append(role_id)
                await cur.execute(f"""
                    UPDATE system_role SET {', '.join(updates)}
                    WHERE id = %s
                """, values)

            # 更新菜单权限
            if request.menu_ids is not None:
                await cur.execute("DELETE FROM system_role_menu WHERE role_id = %s", (role_id,))
                for menu_id in request.menu_ids:
                    await cur.execute("""
                        INSERT INTO system_role_menu (role_id, menu_id)
                        VALUES (%s, %s)
                        ON CONFLICT (role_id, menu_id) DO NOTHING
                    """, (role_id, menu_id))

            await conn.commit()

    return {"message": "角色更新成功"}


@app.delete("/api/v1/system/roles/{role_id}")
async def delete_role(role_id: str, current_user: Dict = Depends(get_current_user)):
    """删除角色（软删除）"""
    if not current_user:
        raise HTTPException(status_code=401, detail="未登录")

    if not await has_permission(current_user['user_id'], 'system:role:delete'):
        raise HTTPException(status_code=403, detail="无权限删除角色")

    async with pool.connection() as conn:
        async with conn.cursor() as cur:
            await cur.execute("SELECT type FROM system_role WHERE id = %s AND deleted_at IS NULL", (role_id,))
            role = await cur.fetchone()
            if not role:
                raise HTTPException(status_code=404, detail="角色不存在")

            # 系统内置角色不能删除
            if role[0] == 1:
                raise HTTPException(status_code=400, detail="系统内置角色不能删除")

            await cur.execute("""
                UPDATE system_role SET deleted_at = NOW()
                WHERE id = %s
            """, (role_id,))
            await conn.commit()

    return {"message": "角色删除成功"}


