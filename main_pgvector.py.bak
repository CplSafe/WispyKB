@app.put("/api/v1/user/profile")
async def update_user_profile(
    username: Optional[str] = Form(None),
    email: Optional[str] = Form(None),
    avatar: Optional[str] = Form(None),
    user: Dict = Depends(get_current_user)
):
    """更新用户资料"""
    if not user:
        raise HTTPException(status_code=401, detail="未登录")

    updates = []
    values = []

    # 检查用户名是否被其他用户占用
    if username is not None:
        async with pool.connection() as conn:
            async with conn.cursor(row_factory=dict_row) as cur:
                await cur.execute(
                    "SELECT id FROM users WHERE username = %s AND id != %s",
                    (username, user['user_id'])
                )
                existing = await cur.fetchone()
                if existing:
                    raise HTTPException(status_code=400, detail="用户名已被其他用户使用")
        updates.append("username = %s")
        values.append(username)

    if email is not None:
        updates.append("email = %s")
        values.append(email)
    if avatar is not None:
        updates.append("avatar = %s")
        values.append(avatar)

    if not updates:
        raise HTTPException(status_code=400, detail="没有要更新的字段")

    values.append(user['user_id'])

    try:
        async with pool.connection() as conn:
            async with conn.cursor(row_factory=dict_row) as cur:
                await cur.execute(
                    f"UPDATE users SET {', '.join(updates)} WHERE id = %s RETURNING id, username, email, role, avatar, created_at",
                    values
                )
                updated_user = await cur.fetchone()
                await conn.commit()
    except Exception as e:
        # 处理数据库唯一约束错误
        if "duplicate key" in str(e) or "UniqueViolation" in str(e):
            raise HTTPException(status_code=400, detail="用户名或邮箱已被使用")
        raise HTTPException(status_code=500, detail="更新失败")

    return {
        "id": updated_user['id'],
        "username": updated_user['username'],
        "email": updated_user['email'],
        "role": updated_user['role'],
        "avatar": updated_user.get('avatar'),
        "created_at": updated_user['created_at'].isoformat() if updated_user['created_at'] else None
    }


# ==================== 统计 API ====================

@app.get("/api/v1/stats/dashboard")
async def get_dashboard_stats(user: Dict = Depends(get_current_user)):
    """获取仪表盘统计数据"""
    async with pool.connection() as conn:
        async with conn.cursor(row_factory=dict_row) as cur:
            # 获取知识库统计
            await cur.execute("SELECT COUNT(*) as count FROM knowledge_bases")
            kb_count = (await cur.fetchone())['count']

            # 获取文档统计
            await cur.execute("SELECT COUNT(*) as count, SUM(chunk_count) as token_count FROM documents WHERE status = 'completed'")
            doc_stats = await cur.fetchone()

            # 获取应用统计
            await cur.execute("SELECT COUNT(*) as count FROM applications")
            app_count = (await cur.fetchone())['count']

            # 获取会话统计 - 使用 chat_messages 表
            await cur.execute("SELECT COUNT(DISTINCT message_id) as count FROM chat_messages")
            message_count = (await cur.fetchone())['count']

            # 获取应用使用情况（基于 chat_messages 表）
            await cur.execute("""
                SELECT a.id,
                       a.name,
                       a.description,
                       COALESCE(c.msg_count, 0) as message_count,
                       COALESCE(f.like_count, 0) as like_count,
                       COALESCE(f.dislike_count, 0) as dislike_count,
                       COALESCE(f.feedback_count, 0) as feedback_count,
                       a.created_at
                FROM applications a
                LEFT JOIN (
                    SELECT application_id,
                           COUNT(*) as msg_count
                    FROM chat_messages
                    GROUP BY application_id
                ) c ON a.id = c.application_id
                LEFT JOIN (
                    SELECT application_id,
                           SUM(CASE WHEN feedback_type = 'like' THEN 1 ELSE 0 END) as like_count,
                           SUM(CASE WHEN feedback_type = 'dislike' THEN 1 ELSE 0 END) as dislike_count,
                           COUNT(*) as feedback_count
                    FROM message_feedback
                    GROUP BY application_id
                ) f ON f.application_id = a.id
                ORDER BY c.msg_count DESC NULLS LAST, a.created_at DESC
            """)
            app_usage = await cur.fetchall()

            # 获取最近7天的消息趋势 - 使用 chat_messages 表
            await cur.execute("""
                SELECT DATE(created_at) as date,
                       COUNT(*) as count
                FROM chat_messages
                WHERE created_at >= NOW() - INTERVAL '7 days'
                GROUP BY DATE(created_at)
                ORDER BY date DESC
                LIMIT 7
            """)
            message_trend = await cur.fetchall()

            # 获取反馈统计
            await cur.execute("""
                SELECT SUM(CASE WHEN feedback_type = 'like' THEN 1 ELSE 0 END) as total_likes,
                       SUM(CASE WHEN feedback_type = 'dislike' THEN 1 ELSE 0 END) as total_dislikes,
                       COUNT(*) as total_feedback
                FROM message_feedback
            """)
            feedback_stats = await cur.fetchone()

    return {
        "knowledge_bases": {
            "total": kb_count
        },
        "documents": {
            "total": doc_stats['count'] if doc_stats else 0,
            "token_count": doc_stats['token_count'] if doc_stats else 0
        },
        "applications": {
            "total": app_count,
            "usage": app_usage
        },
        "messages": {
            "total": message_count,
            "trend": message_trend
        },
        "feedback": {
            "total_likes": feedback_stats['total_likes'] if feedback_stats else 0,
            "total_dislikes": feedback_stats['total_dislikes'] if feedback_stats else 0,
            "total_feedback": feedback_stats['total_feedback'] if feedback_stats else 0
        }
    }


# NOTE: Applications, Share, Chat, and Sessions API endpoints have been moved to api/applications.py and api/chat.py
# The following endpoints are now handled by the respective router modules:
# - /api/v1/applications (GET, POST, DELETE, PUT, /{app_id}/analytics)
# - /api/v1/share/{share_id} (GET, POST /chat, POST /feedback)
# - /api/v1/applications/{app_id}/chat (POST)
# - /api/v1/applications/{app_id}/sessions (GET)
# - /api/v1/sessions/{session_id}/messages (GET)
# - /api/v1/sessions/{session_id} (DELETE)
# - /api/v1/sessions/{session_id}/title (PUT)


@app.get("/api/v1/applications")
async def list_applications(user: Dict = Depends(get_current_user)):
    """获取应用列表（包含反馈统计）

    权限规则：
    - 超级管理员：查看所有应用
    - 普通用户：查看自己的应用 + 公开应用（is_public = true）
    """
    async with pool.connection() as conn:
        async with conn.cursor(row_factory=dict_row) as cur:
            # 获取用户角色
            await cur.execute("SELECT role FROM users WHERE id = %s", (user['user_id'],))
            user_row = await cur.fetchone()
            user_role = user_row['role'] if user_row else 'user'

            # 超级管理员可以查看所有应用
            # 普通用户只能查看自己的应用或公开的应用
            if user_role == 'super_admin':
                where_clause = ""
                params = ()
            else:
                where_clause = "WHERE a.owner_id = %s OR a.is_public = true"
                params = (user['user_id'],)

            await cur.execute(f"""
                SELECT a.*,
                       u.username as owner_name,
                       u.avatar as owner_avatar,
                       COALESCE(c.conv_count, 0) as conversation_count,
                       COALESCE(c.msg_count, 0) as message_count,
                       COALESCE(f.like_count, 0) as like_count,
                       COALESCE(f.dislike_count, 0) as dislike_count,
                       COALESCE(f.feedback_count, 0) as feedback_count
                FROM applications a
                LEFT JOIN users u ON a.owner_id = u.id
                LEFT JOIN (
                    SELECT c.app_id,
                           COUNT(DISTINCT c.id) as conv_count,
                           COALESCE(SUM(m.msg_count), 0) as msg_count
                    FROM conversations c
                    LEFT JOIN (
                        SELECT conversation_id, COUNT(*) as msg_count
                        FROM messages
                        GROUP BY conversation_id
                    ) m ON m.conversation_id = c.id
                    GROUP BY c.app_id
                ) c ON a.id = c.app_id
                LEFT JOIN (
                    SELECT application_id,
                           SUM(CASE WHEN feedback_type = 'like' THEN 1 ELSE 0 END) as like_count,
                           SUM(CASE WHEN feedback_type = 'dislike' THEN 1 ELSE 0 END) as dislike_count,
                           COUNT(*) as feedback_count
                    FROM message_feedback
                    GROUP BY application_id
                ) f ON f.application_id = a.id
                {where_clause}
                ORDER BY a.created_at DESC
            """, params)
            rows = await cur.fetchall()

    return {"applications": rows}


@app.post("/api/v1/applications")
async def create_application(request: CreateApplicationRequest, user: Dict = Depends(get_current_user)):
    """创建应用"""
    if not user:
        raise HTTPException(status_code=401, detail="请先登录")

    app_id = str(uuid.uuid4())
    # 生成分享ID（8位随机字符串）
    share_id = secrets.token_urlsafe(8)

    async with pool.connection() as conn:
        async with conn.cursor() as cur:
            await cur.execute("""
                INSERT INTO applications (id, name, description, model, knowledge_base_ids, is_public, owner_id, system_prompt, welcome_message, share_password, share_id, temperature, max_tokens, created_at, updated_at)
                VALUES (%s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, NOW(), NOW())
                RETURNING id
            """, (app_id, request.name, request.description, request.model,
                  request.knowledge_base_ids, request.is_public, user['user_id'],
                  request.system_prompt, request.welcome_message, request.share_password, share_id,
                  request.temperature, request.max_tokens))
            await conn.commit()

    return {
        "id": app_id,
        "share_id": share_id,
        "name": request.name,
        "message": "应用创建成功"
    }


@app.delete("/api/v1/applications/{app_id}")
async def delete_application(app_id: str, user: Dict = Depends(get_current_user)):
