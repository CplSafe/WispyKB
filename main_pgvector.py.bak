# ==================== 资源授权 API ====================

@app.get("/api/v1/resources/{resource_type}/{resource_id}/permissions")
async def get_resource_permissions(
    resource_type: str,
    resource_id: str,
    user: Dict = Depends(get_current_user)
):
    """获取资源的授权列表"""
    if not user:
        raise HTTPException(status_code=401, detail="未登录")

    # 验证资源类型
    if resource_type not in ['knowledge_base', 'application']:
        raise HTTPException(status_code=400, detail="无效的资源类型")

    async with pool.connection() as conn:
        async with conn.cursor(row_factory=dict_row) as cur:
            # 检查用户是否有权限查看此资源的授权列表
            if resource_type == 'knowledge_base':
                await cur.execute("""
                    SELECT owner_id FROM knowledge_bases WHERE id = %s
                """, (resource_id,))
            else:
                await cur.execute("""
                    SELECT owner_id FROM applications WHERE id = %s
                """, (resource_id,))

            resource = await cur.fetchone()
            if not resource:
                raise HTTPException(status_code=404, detail="资源不存在")

            # 只有所有者或 super_admin 可以查看
            if resource['owner_id'] != user['user_id'] and user.get('role') != 'super_admin':
                raise HTTPException(status_code=403, detail="无权限访问此资源")

            # 获取授权列表
            await cur.execute("""
                SELECT rp.*, u.username, u.email
                FROM resource_permissions rp
                LEFT JOIN users u ON rp.user_id = u.id
                WHERE rp.resource_type = %s AND rp.resource_id = %s
                ORDER BY rp.granted_at DESC
            """, (resource_type, resource_id))
            permissions = await cur.fetchall()

            return {
                "permissions": [
                    {
                        "id": p['id'],
                        "user_id": p['user_id'],
                        "username": p['username'],
                        "email": p['email'],
                        "permission": p['permission'],
                        "granted_at": p['granted_at'].isoformat() if p['granted_at'] else None,
                    }
                    for p in permissions
                ]
            }


@app.post("/api/v1/resources/{resource_type}/{resource_id}/permissions")
async def grant_resource_permission(
    resource_type: str,
    resource_id: str,
    request: ResourcePermissionRequest,
    user: Dict = Depends(get_current_user)
):
    """授权资源给用户"""
    if not user:
        raise HTTPException(status_code=401, detail="未登录")

    # 验证资源类型
    if resource_type not in ['knowledge_base', 'application']:
        raise HTTPException(status_code=400, detail="无效的资源资源类型")

    # 验证权限类型
    if request.permission not in ['read', 'write', 'admin']:
        raise HTTPException(status_code=400, detail="无效的权限类型")

    async with pool.connection() as conn:
        async with conn.cursor(row_factory=dict_row) as cur:
            # 检查资源所有权
            if resource_type == 'knowledge_base':
                await cur.execute("""
                    SELECT owner_id FROM knowledge_bases WHERE id = %s
                """, (resource_id,))
            else:
                await cur.execute("""
                    SELECT owner_id FROM applications WHERE id = %s
                """, (resource_id,))

            resource = await cur.fetchone()
            if not resource:
                raise HTTPException(status_code=404, detail="资源不存在")

            # 只有所有者或 super_admin 可以授权
            if resource['owner_id'] != user['user_id'] and user.get('role') != 'super_admin':
                raise HTTPException(status_code=403, detail="只有资源所有者可以授权")

            # 检查目标用户是否存在
            await cur.execute("SELECT id, username FROM users WHERE id = %s", (request.user_id,))
            target_user = await cur.fetchone()
            if not target_user:
                raise HTTPException(status_code=404, detail="用户不存在")

            # 检查是否已授权
            await cur.execute("""
                SELECT * FROM resource_permissions
                WHERE resource_type = %s AND resource_id = %s AND user_id = %s
            """, (resource_type, resource_id, request.user_id))
            existing = await cur.fetchone()

            if existing:
                # 更新权限
                await cur.execute("""
                    UPDATE resource_permissions
                    SET permission = %s, granted_by = %s, granted_at = NOW()
                    WHERE resource_type = %s AND resource_id = %s AND user_id = %s
                """, (request.permission, user['user_id'], resource_type, resource_id, request.user_id))
            else:
                # 新增授权
                perm_id = str(uuid.uuid4())
                await cur.execute("""
                    INSERT INTO resource_permissions (id, resource_type, resource_id, user_id, permission, granted_by)
                    VALUES (%s, %s, %s, %s, %s, %s)
                """, (perm_id, resource_type, resource_id, request.user_id, request.permission, user['user_id']))

            await conn.commit()

            return {
                "user_id": request.user_id,
                "username": target_user['username'],
                "permission": request.permission,
                "message": "授权成功"
            }


@app.delete("/api/v1/resources/{resource_type}/{resource_id}/permissions/{permission_id}")
async def revoke_resource_permission(
    resource_type: str,
    resource_id: str,
    permission_id: str,
    user: Dict = Depends(get_current_user)
):
    """撤销资源授权"""
    if not user:
        raise HTTPException(status_code=401, detail="未登录")

    async with pool.connection() as conn:
        async with conn.cursor(row_factory=dict_row) as cur:
            # 检查资源所有权
            if resource_type == 'knowledge_base':
                await cur.execute("""
                    SELECT owner_id FROM knowledge_bases WHERE id = %s
                """, (resource_id,))
            else:
                await cur.execute("""
                    SELECT owner_id FROM applications WHERE id = %s
                """, (resource_id,))

            resource = await cur.fetchone()
            if not resource:
                raise HTTPException(status_code=404, detail="资源不存在")

            # 只有所有者或 super_admin 可以撤销授权
            if resource['owner_id'] != user['user_id'] and user.get('role') != 'super_admin':
                raise HTTPException(status_code=403, detail="只有资源所有者可以撤销授权")

            await cur.execute("""
                DELETE FROM resource_permissions
                WHERE id = %s AND resource_type = %s AND resource_id = %s
            """, (permission_id, resource_type, resource_id))
            await conn.commit()

            if cur.rowcount == 0:
                raise HTTPException(status_code=404, detail="授权不存在")

            return {"message": "授权已撤销"}


@app.get("/api/v1/user/accessible-resources")
async def get_user_accessible_resources(
    resource_type: Optional[str] = None,
    user: Dict = Depends(get_current_user)
):
    """获取用户有权访问的所有资源（包括拥有的和被授权的）"""
    if not user:
        raise HTTPException(status_code=401, detail="未登录")

    async with pool.connection() as conn:
        async with conn.cursor(row_factory=dict_row) as cur:
            resources = {"knowledge_bases": [], "applications": []}

            # 获取用户拥有的知识库
            await cur.execute("""
                SELECT id, name, description, owner_id, created_at
                FROM knowledge_bases
                WHERE owner_id = %s
                ORDER BY created_at DESC
            """, (user['user_id'],))
            owned_kbs = await cur.fetchall()

            # 获取用户被授权的知识库
            await cur.execute("""
                SELECT DISTINCT kb.id, kb.name, kb.description, kb.owner_id, kb.created_at
                FROM knowledge_bases kb
                INNER JOIN resource_permissions rp ON rp.resource_id = kb.id
                WHERE rp.resource_type = 'knowledge_base'
                AND rp.user_id = %s
                AND rp.permission IN ('read', 'write', 'admin')
                ORDER BY kb.created_at DESC
            """, (user['user_id'],))
            granted_kbs = await cur.fetchall()

            # 合并去重
            kb_ids = set()
            for kb in owned_kbs + granted_kbs:
                if kb['id'] not in kb_ids:
                    kb_ids.add(kb['id'])
                    resources['knowledge_bases'].append({
                        "id": kb['id'],
                        "name": kb['name'],
                        "description": kb['description'],
                        "owner_id": kb['owner_id'],
                        "is_owner": kb['owner_id'] == user['user_id'],
                        "created_at": kb['created_at'].isoformat() if kb['created_at'] else None,
                    })

            # 获取用户拥有的应用
            await cur.execute("""
                SELECT id, name, description, owner_id, created_at
                FROM applications
                WHERE owner_id = %s
                ORDER BY created_at DESC
            """, (user['user_id'],))
            owned_apps = await cur.fetchone()

            # 获取用户被授权的应用
            await cur.execute("""
                SELECT DISTINCT app.id, app.name, app.description, app.owner_id, app.created_at
                FROM applications app
                INNER JOIN resource_permissions rp ON rp.resource_id = app.id
                WHERE rp.resource_type = 'application'
                AND rp.user_id = %s
                AND rp.permission IN ('read', 'write', 'admin')
                ORDER BY app.created_at DESC
            """, (user['user_id'],))
            granted_apps = await cur.fetchall()

            # 合并去重
            app_ids = set()
            for app in owned_apps + granted_apps:
                if app['id'] not in app_ids:
                    app_ids.add(app['id'])
                    resources['applications'].append({
                        "id": app['id'],
                        "name": app['name'],
                        "description": app['description'],
                        "owner_id": app['owner_id'],
                        "is_owner": app['owner_id'] == user['user_id'],
                        "created_at": app['created_at'].isoformat() if app['created_at'] else None,
                    })

            if resource_type == 'knowledge_base':
                return {"knowledge_bases": resources['knowledge_bases']}
            elif resource_type == 'application':
                return {"applications": resources['applications']}
            else:
                return resources


@app.get("/api/v1/users/search")
async def search_users(
    q: str = "",
    user: Dict = Depends(get_current_user)
):
    """搜索用户（用于添加成员或授权）"""
    if not user:
        raise HTTPException(status_code=401, detail="未登录")

    if user.get('role') not in ['super_admin', 'workspace_admin']:
        raise HTTPException(status_code=403, detail="只有管理员可以搜索用户")

    async with pool.connection() as conn:
        async with conn.cursor(row_factory=dict_row) as cur:
            await cur.execute("""
                SELECT id, username, email, avatar, role
                FROM users
                WHERE username ILIKE %s OR email ILIKE %s
                LIMIT 20
            """, (f"%{q}%", f"%{q}%"))
            users = await cur.fetchall()

            return {
                "users": [
                    {
                        "id": u['id'],
                        "username": u['username'],
                        "email": u['email'],
                        "avatar": u['avatar'],
                        "role": u['role'],
                    }
                    for u in users
                ]
            }


# ==================== 审计日志 API ====================

@app.get("/api/v1/audit/logs")
async def get_audit_logs(
    entity_type: Optional[str] = None,
    entity_id: Optional[str] = None,
    action: Optional[str] = None,
    user_id: Optional[str] = None,
    page: int = 1,
    page_size: int = 50,
    user: Dict = Depends(get_current_user)
):
    """
    获取审计日志（仅超级管理员）

    Args:
        entity_type: 实体类型过滤 (knowledge_base, document, chunk, application)
        entity_id: 实体ID过滤
        action: 操作类型过滤 (create, update, delete)
        user_id: 用户ID过滤
        page: 页码
        page_size: 每页数量
    """
    if not user:
        raise HTTPException(status_code=401, detail="未登录")

    # 只有超级管理员可以查看审计日志
    if user.get('role') != 'super_admin':
        raise HTTPException(status_code=403, detail="只有超级管理员可以查看审计日志")

    offset = (page - 1) * page_size

    # 构建查询条件
    conditions = []
    params = []

    if entity_type:
        conditions.append("entity_type = %s")
        params.append(entity_type)
    if entity_id:
        conditions.append("entity_id = %s")
        params.append(entity_id)
    if action:
        conditions.append("action = %s")
        params.append(action)
    if user_id:
        conditions.append("user_id = %s")
        params.append(user_id)

    where_clause = f"WHERE {' AND '.join(conditions)}" if conditions else ""

    async with pool.connection() as conn:
        async with conn.cursor(row_factory=dict_row) as cur:
            # 获取总数
            await cur.execute(f"""
                SELECT COUNT(*) as total FROM audit_logs {where_clause}
            """, params)
            total = await cur.fetchone()

            # 获取日志
            params.append(page_size)
            params.append(offset)
            await cur.execute(f"""
                SELECT
                    id,
                    entity_type,
                    entity_id,
                    action,
                    user_id,
                    username,
                    changes,
                    ip_address,
                    user_agent,
                    created_at
                FROM audit_logs
                {where_clause}
                ORDER BY created_at DESC
                LIMIT %s OFFSET %s
            """, params)
            logs = await cur.fetchall()

    return {
        "logs": [
            {
                "id": log['id'],
                "entity_type": log['entity_type'],
                "entity_id": log['entity_id'],
                "action": log['action'],
                "user_id": log['user_id'],
                "username": log['username'],
                "changes": log['changes'],
                "ip_address": log['ip_address'],
                "user_agent": log['user_agent'],
                "created_at": log['created_at'].isoformat() if log['created_at'] else None
            }
            for log in logs
        ],
        "total": total['total'] if total else 0,
        "page": page,
        "page_size": page_size
    }


@app.get("/api/v1/audit/stats")
async def get_audit_stats(
    user: Dict = Depends(get_current_user)
):
    """
    获取审计统计数据（仅超级管理员）
    """
    if not user:
        raise HTTPException(status_code=401, detail="未登录")

    if user.get('role') != 'super_admin':
        raise HTTPException(status_code=403, detail="只有超级管理员可以查看审计统计")

    async with pool.connection() as conn:
        async with conn.cursor(row_factory=dict_row) as cur:
            # 总操作数
            await cur.execute("SELECT COUNT(*) as count FROM audit_logs")
            total_count = (await cur.fetchone())['count']

            # 按实体类型统计
            await cur.execute("""
                SELECT entity_type, COUNT(*) as count
                FROM audit_logs
                GROUP BY entity_type
                ORDER BY count DESC
            """)
            by_entity_type = await cur.fetchall()

            # 按操作类型统计
            await cur.execute("""
                SELECT action, COUNT(*) as count
                FROM audit_logs
                GROUP BY action
                ORDER BY count DESC
            """)
            by_action = await cur.fetchall()

            # 按用户统计（最活跃用户）
            await cur.execute("""
                SELECT user_id, username, COUNT(*) as count
                FROM audit_logs
                GROUP BY user_id, username
                ORDER BY count DESC
                LIMIT 10
            """)
            top_users = await cur.fetchall()

            # 最近24小时的活动
            await cur.execute("""
                SELECT COUNT(*) as count
                FROM audit_logs
                WHERE created_at >= NOW() - INTERVAL '24 hours'
            """)
            last_24h = (await cur.fetchone())['count']

    return {
        "total_count": total_count,
        "by_entity_type": [{"type": row['entity_type'], "count": row['count']} for row in by_entity_type],
        "by_action": [{"action": row['action'], "count": row['count']} for row in by_action],
        "top_users": [
            {"user_id": row['user_id'], "username": row['username'], "count": row['count']}
            for row in top_users
        ],
        "last_24h_count": last_24h
    }


@app.get("/api/v1/documents/{doc_id}/history")
async def get_document_history(
    doc_id: str,
    user: Dict = Depends(get_current_user)
):
    """
    获取文档的修改历史（包括分块修改）

    用于显示文档内容谁修改了、原来是什么、修改后是什么
    """
    if not user:
        raise HTTPException(status_code=401, detail="未登录")

    # 只有超级管理员或文档创建者可以查看
    async with pool.connection() as conn:
        async with conn.cursor(row_factory=dict_row) as cur:
            # 检查文档权限
            await cur.execute("""
                SELECT d.*, kb.owner_id
                FROM documents d
                JOIN knowledge_bases kb ON d.kb_id = kb.id
                WHERE d.id = %s
            """, (doc_id,))
            doc = await cur.fetchone()

            if not doc:
                raise HTTPException(status_code=404, detail="文档不存在")

            # 检查权限：超级管理员或知识库所有者
            if user.get('role') != 'super_admin' and doc.get('owner_id') != user.get('user_id'):
                # 再检查是否是文档创建者
                if doc.get('created_by') != user.get('user_id'):
                    raise HTTPException(status_code=403, detail="没有权限查看文档历史")

            # 获取文档级别的审计日志
            await cur.execute("""
                SELECT id, entity_type, entity_id, action, user_id, username, changes, created_at
                FROM audit_logs
                WHERE (entity_type = 'document' AND entity_id = %s)
                   OR (entity_type = 'chunk' AND entity_id IN (
                       SELECT id FROM chunks WHERE doc_id = %s
                   ))
                ORDER BY created_at DESC
            """, (doc_id, doc_id))
            logs = await cur.fetchall()

            # 获取文档名称
            doc_name = doc.get('name', '未知文档')

    return {
        "doc_id": doc_id,
        "doc_name": doc_name,
        "history": [
            {
                "id": log['id'],
                "entity_type": log['entity_type'],
                "entity_id": log['entity_id'],
                "action": log['action'],
                "user_id": log['user_id'],
                "username": log['username'],
                "changes": log['changes'],
                "created_at": log['created_at'].isoformat() if log['created_at'] else None
            }
            for log in logs
        ]
    }


# ==================== 部门管理 API ====================

class CreateDepartmentRequest(BaseModel):
    name: str
    code: str
    description: Optional[str] = None
    parent_id: Optional[str] = None


class UpdateDepartmentRequest(BaseModel):
    name: Optional[str] = None
    description: Optional[str] = None
    parent_id: Optional[str] = None
    is_active: Optional[bool] = None


class AssignUserDepartmentRequest(BaseModel):
    user_id: str
    department_id: str
    position: Optional[str] = None
    is_primary: bool = True
    is_manager: bool = False


@app.get("/api/v1/departments")
async def list_departments(user: Dict = Depends(get_current_user)):
    """获取部门列表（树形结构）"""
    if not user:
        raise HTTPException(status_code=401, detail="未登录")

    if user.get('role') != 'super_admin':
        raise HTTPException(status_code=403, detail="只有超级管理员可以管理部门")

    async with pool.connection() as conn:
        async with conn.cursor(row_factory=dict_row) as cur:
            await cur.execute("""
                SELECT d.*,
                       p.name as parent_name,
                       creator.username as created_by_name,
                       COUNT(ud.user_id) as member_count
                FROM departments d
                LEFT JOIN departments p ON d.parent_id = p.id
                LEFT JOIN users creator ON d.created_by = creator.id
                LEFT JOIN user_departments ud ON d.id = ud.department_id
                GROUP BY d.id, p.name, creator.username
                ORDER BY d.sort_order, d.name
            """)
            departments = await cur.fetchall()

            # 获取每个部门的成员
            dept_ids = [d['id'] for d in departments]
            members = {}
            if dept_ids:
                await cur.execute(f"""
                    SELECT ud.department_id, u.id, u.username, u.email, u.avatar,
                           ud.position, ud.is_primary, ud.is_manager
                    FROM user_departments ud
                    JOIN users u ON ud.user_id = u.id
                    WHERE ud.department_id IN %s
                    ORDER BY ud.is_primary DESC, u.username
                """, (tuple(dept_ids),))
                for row in await cur.fetchall():
                    dept_id = row['department_id']
                    if dept_id not in members:
                        members[dept_id] = []
                    members[dept_id].append({
                        'id': row['id'],
                        'username': row['username'],
                        'email': row['email'],
                        'avatar': row['avatar'],
                        'position': row['position'],
                        'is_primary': row['is_primary'],
                        'is_manager': row['is_manager'],
                    })

    return {
        "departments": [
            {
                **d,
                'members': members.get(d['id'], [])
            }
            for d in departments
        ]
    }


@app.get("/api/v1/departments/tree")
async def get_department_tree(user: Dict = Depends(get_current_user)):
    """获取部门树形结构"""
    if not user:
        raise HTTPException(status_code=401, detail="未登录")

    if user.get('role') != 'super_admin':
        raise HTTPException(status_code=403, detail="只有超级管理员可以管理部门")

    async with pool.connection() as conn:
        async with conn.cursor(row_factory=dict_row) as cur:
            await cur.execute("""
                SELECT d.*, COUNT(ud.user_id) as member_count
                FROM departments d
                LEFT JOIN user_departments ud ON d.id = ud.department_id
                WHERE d.is_active = true
                GROUP BY d.id
                ORDER BY d.sort_order, d.name
            """)
            departments = await cur.fetchall()

    def build_tree(parent_id=None):
        return [
            {
                **d,
                'children': build_tree(d['id'])
            }
            for d in departments
            if d['parent_id'] == parent_id
        ]

    return {"tree": build_tree()}


@app.post("/api/v1/departments")
async def create_department(
    request: CreateDepartmentRequest,
    user: Dict = Depends(get_current_user)
):
    """创建部门"""
    if not user:
        raise HTTPException(status_code=401, detail="未登录")

    if user.get('role') != 'super_admin':
        raise HTTPException(status_code=403, detail="只有超级管理员可以创建部门")

    async with pool.connection() as conn:
        async with conn.cursor() as cur:
            # 检查代码是否已存在
            await cur.execute("SELECT id FROM departments WHERE code = %s", (request.code,))
            if await cur.fetchone():
                raise HTTPException(status_code=400, detail="部门代码已存在")

            # 检查父部门是否存在
            if request.parent_id:
                await cur.execute("SELECT id FROM departments WHERE id = %s", (request.parent_id,))
                if not await cur.fetchone():
                    raise HTTPException(status_code=400, detail="父部门不存在")

            dept_id = str(uuid.uuid4())
            await cur.execute("""
                INSERT INTO departments (id, name, code, description, parent_id, created_by, created_at, updated_at)
                VALUES (%s, %s, %s, %s, %s, %s, NOW(), NOW())
                RETURNING id
            """, (dept_id, request.name, request.code, request.description, request.parent_id, user['user_id']))
            await conn.commit()

    return {"id": dept_id, "message": "部门创建成功"}


@app.put("/api/v1/departments/{dept_id}")
async def update_department(
    dept_id: str,
    request: UpdateDepartmentRequest,
    user: Dict = Depends(get_current_user)
):
    """更新部门"""
    if not user:
        raise HTTPException(status_code=401, detail="未登录")

    if user.get('role') != 'super_admin':
        raise HTTPException(status_code=403, detail="只有超级管理员可以修改部门")

    async with pool.connection() as conn:
        async with conn.cursor() as cur:
            await cur.execute("SELECT * FROM departments WHERE id = %s", (dept_id,))
            dept = await cur.fetchone()
            if not dept:
                raise HTTPException(status_code=404, detail="部门不存在")

            updates = []
            values = []

            if request.name is not None:
                updates.append("name = %s")
                values.append(request.name)
            if request.description is not None:
                updates.append("description = %s")
                values.append(request.description)
            if request.parent_id is not None:
                if request.parent_id == dept_id:
                    raise HTTPException(status_code=400, detail="不能将部门设置为自己的子部门")
                updates.append("parent_id = %s")
                values.append(request.parent_id)
            if request.is_active is not None:
                updates.append("is_active = %s")
                values.append(request.is_active)

            if updates:
                updates.append("updated_at = NOW()")
                values.append(dept_id)
                await cur.execute(f"""
                    UPDATE departments SET {', '.join(updates)}
                    WHERE id = %s
                """, values)
                await conn.commit()

    return {"message": "部门更新成功"}


@app.delete("/api/v1/departments/{dept_id}")
async def delete_department(
    dept_id: str,
    user: Dict = Depends(get_current_user)
):
    """删除部门"""
    if not user:
        raise HTTPException(status_code=401, detail="未登录")

    if user.get('role') != 'super_admin':
        raise HTTPException(status_code=403, detail="只有超级管理员可以删除部门")

    async with pool.connection() as conn:
        async with conn.cursor() as cur:
            # 检查是否有子部门
            await cur.execute("SELECT COUNT(*) as count FROM departments WHERE parent_id = %s", (dept_id,))
            child_count = (await cur.fetchone())['count']
            if child_count > 0:
                raise HTTPException(status_code=400, detail="请先删除子部门")

            # 删除用户部门关联
            await cur.execute("DELETE FROM user_departments WHERE department_id = %s", (dept_id,))

            # 删除部门
            await cur.execute("DELETE FROM departments WHERE id = %s", (dept_id,))
            await conn.commit()

    return {"message": "部门删除成功"}


@app.post("/api/v1/departments/assign-user")
async def assign_user_department(
    request: AssignUserDepartmentRequest,
    user: Dict = Depends(get_current_user)
):
    """分配用户到部门"""
    if not user:
        raise HTTPException(status_code=401, detail="未登录")

    if user.get('role') != 'super_admin':
        raise HTTPException(status_code=403, detail="只有超级管理员可以分配部门")

    async with pool.connection() as conn:
        async with conn.cursor() as cur:
            # 检查用户是否存在
            await cur.execute("SELECT id FROM users WHERE id = %s", (request.user_id,))
            if not await cur.fetchone():
                raise HTTPException(status_code=404, detail="用户不存在")

            # 检查部门是否存在
            await cur.execute("SELECT id FROM departments WHERE id = %s", (request.department_id,))
            if not await cur.fetchone():
                raise HTTPException(status_code=404, detail="部门不存在")

            # 如果设置为主部门，先清除用户的其他主部门
            if request.is_primary:
                await cur.execute("""
                    UPDATE user_departments SET is_primary = false
                    WHERE user_id = %s AND department_id != %s
                """, (request.user_id, request.department_id))

            # 删除已存在的关联
            await cur.execute("""
                DELETE FROM user_departments
                WHERE user_id = %s AND department_id = %s
            """, (request.user_id, request.department_id))

            # 创建新的关联
            await cur.execute("""
                INSERT INTO user_departments (user_id, department_id, position, is_primary, is_manager, joined_at)
                VALUES (%s, %s, %s, %s, %s, NOW())
            """, (request.user_id, request.department_id, request.position,
                  request.is_primary, request.is_manager))
            await conn.commit()

    return {"message": "用户分配部门成功"}


@app.delete("/api/v1/departments/{dept_id}/users/{user_id}")
async def remove_user_from_department(
    dept_id: str,
    user_id: str,
    user: Dict = Depends(get_current_user)
):
    """从部门移除用户"""
    if not user:
        raise HTTPException(status_code=401, detail="未登录")

    if user.get('role') != 'super_admin':
        raise HTTPException(status_code=403, detail="只有超级管理员可以管理部门成员")

    async with pool.connection() as conn:
        async with conn.cursor() as cur:
            await cur.execute("""
                DELETE FROM user_departments
                WHERE user_id = %s AND department_id = %s
            """, (user_id, dept_id))
            await conn.commit()

    return {"message": "用户已从部门移除"}


@app.get("/api/v1/users/{user_id}/departments")
async def get_user_departments(
    user_id: str,
    user: Dict = Depends(get_current_user)
):
    """获取用户的部门列表"""
    if not user:
        raise HTTPException(status_code=401, detail="未登录")

    async with pool.connection() as conn:
        async with conn.cursor(row_factory=dict_row) as cur:
            await cur.execute("""
                SELECT ud.id, ud.position, ud.is_primary, ud.is_manager, ud.joined_at,
                       d.id as department_id, d.name as department_name, d.code as department_code
                FROM user_departments ud
                JOIN departments d ON ud.department_id = d.id
                WHERE ud.user_id = %s
                ORDER BY ud.is_primary DESC, d.name
            """, (user_id,))
            user_depts = await cur.fetchall()

    return {"departments": user_depts}


# ==================== RBAC 权限管理 API ====================
# 参考 RuoYi-Vue-Pro 的权限模型实现

class CreateUserRequest(BaseModel):
    """创建用户请求"""
    username: str
    password: str
    email: Optional[str] = None
    nickname: Optional[str] = None
    mobile: Optional[str] = None
    dept_id: Optional[str] = None
    post_ids: Optional[List[str]] = []
    role_ids: Optional[List[str]] = []
    avatar: Optional[str] = None
    status: Optional[int] = 0


class UpdateUserRequest(BaseModel):
    """更新用户请求"""
    email: Optional[str] = None
    nickname: Optional[str] = None
    mobile: Optional[str] = None
    dept_id: Optional[str] = None
    post_ids: Optional[List[str]] = []
    avatar: Optional[str] = None
    status: Optional[int] = None


class CreateRoleRequest(BaseModel):
    """创建角色请求"""
    name: str
    code: str
    sort: Optional[int] = 0
    status: Optional[int] = 0
    data_scope: Optional[int] = 5  # 默认仅本人数据
    remark: Optional[str] = None
    menu_ids: Optional[List[str]] = []


class UpdateRoleRequest(BaseModel):
    """更新角色请求"""
    name: Optional[str] = None
    sort: Optional[int] = None
    status: Optional[int] = None
    data_scope: Optional[int] = None
    remark: Optional[str] = None
    menu_ids: Optional[List[str]] = None


class CreateMenuRequest(BaseModel):
    """创建菜单请求"""
    name: str
    permission: Optional[str] = None
    type: int  # 1=目录 2=菜单 3=按钮
    sort: Optional[int] = 0
    parent_id: Optional[str] = '0'
    path: Optional[str] = None
    icon: Optional[str] = None
    component: Optional[str] = None
    component_name: Optional[str] = None
    status: Optional[int] = 0
    visible: Optional[bool] = True
    keep_alive: Optional[bool] = False
    always_show: Optional[bool] = False


class UpdateMenuRequest(BaseModel):
    """更新菜单请求"""
    name: Optional[str] = None
    permission: Optional[str] = None
    sort: Optional[int] = None
    parent_id: Optional[str] = None
    path: Optional[str] = None
    icon: Optional[str] = None
    component: Optional[str] = None
    component_name: Optional[str] = None
    status: Optional[int] = None
    visible: Optional[bool] = None
    keep_alive: Optional[bool] = None
    always_show: Optional[bool] = None


class AssignRoleRequest(BaseModel):
    """分配角色请求"""
    role_ids: List[str]


class GrantResourcePermissionRequest(BaseModel):
    """授予资源权限请求"""
    resource_type: str  # 'knowledge_base', 'application', 'workflow'
    resource_id: str
    user_id: Optional[str] = None
    role_id: Optional[str] = None
    dept_id: Optional[str] = None
    permissions: List[str]  # ['read', 'write', 'delete', 'manage']
    expires_at: Optional[str] = None


# ==================== 权限检查辅助函数 ====================

async def get_user_roles(user_id: str) -> List[Dict]:
    """获取用户的所有角色"""
    async with pool.connection() as conn:
        async with conn.cursor(row_factory=dict_row) as cur:
            await cur.execute("""
                SELECT r.id, r.name, r.code, r.sort, r.status, r.type, r.data_scope
                FROM system_role r
                JOIN system_user_role ur ON r.id = ur.role_id
                WHERE ur.user_id = %s AND r.deleted_at IS NULL AND r.status = 0
                ORDER BY r.sort
            """, (user_id,))
            return await cur.fetchall()


async def get_user_permissions(user_id: str) -> List[str]:
    """获取用户的所有权限（通过角色）"""
    async with pool.connection() as conn:
        async with conn.cursor() as cur:
            await cur.execute("""
                SELECT DISTINCT m.permission
                FROM system_menu m
                JOIN system_role_menu rm ON m.id = rm.menu_id
                JOIN system_user_role ur ON rm.role_id = ur.role_id
                WHERE ur.user_id = %s
                  AND m.permission IS NOT NULL
                  AND m.status = 0
                  AND m.deleted_at IS NULL
            """, (user_id,))
            permissions = await cur.fetchall()
            return [p[0] for p in permissions] if permissions else []


async def has_permission(user_id: str, permission: str) -> bool:
    """检查用户是否有指定权限"""
    # 超级管理员拥有所有权限
    roles = await get_user_roles(user_id)
    if any(r['code'] == 'super_admin' for r in roles):
        return True

    permissions = await get_user_permissions(user_id)
    return permission in permissions


async def has_any_permission(user_id: str, permissions: List[str]) -> bool:
    """检查用户是否有任一指定权限"""
    roles = await get_user_roles(user_id)
    if any(r['code'] == 'super_admin' for r in roles):
        return True

    user_permissions = await get_user_permissions(user_id)
    return any(p in user_permissions for p in permissions)


async def get_data_scope_filter(user_id: str, table_alias: str = '') -> tuple:
    """
    获取数据权限过滤条件

    返回 (where_clause, params) 元组，避免SQL注入
    """
    roles = await get_user_roles(user_id)

    # 超级管理员可以看所有数据
    if any(r['code'] == 'super_admin' for r in roles):
        return "", []

    # 获取用户部门
    async with pool.connection() as conn:
        async with conn.cursor() as cur:
            await cur.execute("SELECT dept_id FROM users WHERE id = %s", (user_id,))
            result = await cur.fetchone()
            user_dept_id = result[0] if result else None

    # 检查角色的数据范围 - 取权限最大的角色
    max_data_scope = 5  # 默认仅本人
    for role in roles:
        data_scope = role.get('data_scope', 5)
        if data_scope < max_data_scope:
            max_data_scope = data_scope

    alias = f"{table_alias}." if table_alias else ""

    if max_data_scope == 1:  # 全部数据权限
        return "", []

    elif max_data_scope == 2:  # 自定义部门数据权限
        # 获取用户所有角色的自定义部门列表
        async with pool.connection() as conn:
            async with conn.cursor() as cur:
                role_ids = [r['id'] for r in roles if r.get('data_scope') == 2]
                if role_ids:
                    placeholders = ','.join(['%s'] * len(role_ids))
                    await cur.execute(f"""
                        SELECT DISTINCT dept_id FROM system_role_data_scope_dept WHERE role_id IN ({placeholders})
                    """, role_ids)
                    dept_ids = [row[0] for row in await cur.fetchall()]
                else:
                    dept_ids = []

        if dept_ids:
            placeholders = ','.join(['%s'] * len(dept_ids))
            return f"{alias}dept_id IN ({placeholders})", dept_ids
        else:
            return f"{alias}1=0", []  # 无权限，返回空结果

    elif max_data_scope == 3:  # 本部门数据权限
        if user_dept_id:
            return f"{alias}dept_id = %s", [user_dept_id]
        else:
            return f"{alias}1=0", []

    elif max_data_scope == 4:  # 本部门及以下数据权限
        if user_dept_id:
            # 获取所有子部门
            async with pool.connection() as conn:
                async with conn.cursor() as cur:
                    await cur.execute("""
                        WITH RECURSIVE dept_tree AS (
                            SELECT id FROM departments WHERE id = %s
                            UNION ALL
                            SELECT d.id FROM departments d
                            JOIN dept_tree dt ON d.parent_id = dt.id
                        )
                        SELECT id FROM dept_tree
                    """, (user_dept_id,))
                    dept_ids = [row[0] for row in await cur.fetchall()]

            if dept_ids:
                placeholders = ','.join(['%s'] * len(dept_ids))
                return f"{alias}dept_id IN ({placeholders})", dept_ids
            else:
                return f"{alias}1=0", []
        else:
            return f"{alias}1=0", []

    else:  # data_scope == 5, 仅本人数据权限
        return f"{alias}created_by = %s", [user_id]


# ==================== 用户管理 API ====================

@app.get("/api/v1/system/users")
async def list_users(
    page: int = 1,
    page_size: int = 20,
    username: Optional[str] = None,
    status: Optional[int] = None,
    dept_id: Optional[str] = None,
    user: Dict = Depends(get_current_user)
):
    """获取用户列表"""
    if not user:
        raise HTTPException(status_code=401, detail="未登录")

    # 验证分页参数
    page, page_size = validate_pagination(page, page_size)

    # 检查权限
    if not await has_permission(user['user_id'], 'system:user:manage'):
        raise HTTPException(status_code=403, detail="无权限访问")

    async with pool.connection() as conn:
        # 构建查询条件
        conditions = ["u.deleted_at IS NULL"]
        params = []

        if username:
            conditions.append("u.username LIKE %s")
            params.append(f"%{username}%")
        if status is not None:
            conditions.append("u.status = %s")
            params.append(status)
        if dept_id:
            conditions.append("u.dept_id = %s")
            params.append(dept_id)

        where_clause = " AND ".join(conditions)

        # 获取总数 - 使用单独的 cursor
        async with conn.cursor(row_factory=dict_row) as cur_count:
            await cur_count.execute(f"""
                SELECT COUNT(*) as total
                FROM users u
                WHERE {where_clause}
            """, params)
            total_result = await cur_count.fetchone()
            total = total_result['total'] if total_result else 0

        # 获取分页数据 - 使用新的 cursor
        offset = (page - 1) * page_size

        async with conn.cursor(row_factory=dict_row) as cur:
            # 注意: LIMIT/OFFSET 使用字符串插值而不是参数，因为 psycopg3 的 dict_row 在复杂查询中对此有问题
            main_query = f"""
                SELECT
                    u.id, u.username, u.email, u.nickname, u.mobile, u.avatar,
                    u.status, u.dept_id, u.created_at::text as created_at,
                    d.name as dept_name,
                    COALESCE(ARRAY_AGG(DISTINCT r.code) FILTER (WHERE r.code IS NOT NULL), ARRAY[]::TEXT[]) as roles,
                    COALESCE(ARRAY_AGG(DISTINCT r.name) FILTER (WHERE r.name IS NOT NULL), ARRAY[]::TEXT[]) as role_names
                FROM users u
                LEFT JOIN departments d ON u.dept_id = d.id
                LEFT JOIN system_user_role ur ON u.id = ur.user_id
                LEFT JOIN system_role r ON ur.role_id = r.id AND r.deleted_at IS NULL
                WHERE {where_clause}
                GROUP BY u.id, u.username, u.email, u.nickname, u.mobile, u.avatar, u.status, u.dept_id, u.created_at, d.name
                ORDER BY u.created_at DESC
                LIMIT {page_size} OFFSET {offset}
            """
            await cur.execute(main_query, params)
            users = await cur.fetchall()

    return {
        "users": users,
        "total": total,
        "page": page,
        "page_size": page_size
    }


@app.get("/api/v1/system/users/{user_id}")
async def get_user(user_id: str, user: Dict = Depends(get_current_user)):
    """获取用户详情"""
    if not user:
        raise HTTPException(status_code=401, detail="未登录")

    # 检查权限（可以查看自己的信息）
    if user['user_id'] != user_id and not await has_permission(user['user_id'], 'system:user:manage'):
        raise HTTPException(status_code=403, detail="无权限访问")

    async with pool.connection() as conn:
        async with conn.cursor(row_factory=dict_row) as cur:
            await cur.execute("""
                SELECT u.*,
                       d.name as dept_name,
                       d.id as dept_id
                FROM users u
                LEFT JOIN departments d ON u.dept_id = d.id
                WHERE u.id = %s AND u.deleted_at IS NULL
            """, (user_id,))
            user_info = await cur.fetchone()

            if not user_info:
                raise HTTPException(status_code=404, detail="用户不存在")

            # 获取用户角色
            await cur.execute("""
                SELECT r.id, r.name, r.code
                FROM system_role r
                JOIN system_user_role ur ON r.id = ur.role_id
                WHERE ur.user_id = %s AND r.deleted_at IS NULL
            """, (user_id,))
            user_info['roles'] = await cur.fetchall()

            # 获取用户岗位
            await cur.execute("""
                SELECT p.id, p.code, p.name
                FROM system_post p
                JOIN system_user_post up ON p.id = up.post_id
                WHERE up.user_id = %s AND p.deleted_at IS NULL
            """, (user_id,))
            user_info['posts'] = await cur.fetchall()

    return user_info


@app.post("/api/v1/system/users")
async def create_user(request: CreateUserRequest, user: Dict = Depends(get_current_user)):
    """创建用户"""
    if not user:
        raise HTTPException(status_code=401, detail="未登录")

    if not await has_permission(user['user_id'], 'system:user:create'):
        raise HTTPException(status_code=403, detail="无权限创建用户")

    try:
        async with pool.connection() as conn:
            async with conn.cursor() as cur:
                # 检查用户名是否已存在
                await cur.execute("SELECT id FROM users WHERE username = %s AND deleted_at IS NULL", (request.username,))
                if await cur.fetchone():
                    raise HTTPException(status_code=400, detail="用户名已存在")

                # 检查邮箱是否已存在
                if request.email:
                    await cur.execute("SELECT id FROM users WHERE email = %s AND deleted_at IS NULL", (request.email,))
                    if await cur.fetchone():
                        raise HTTPException(status_code=400, detail="邮箱已被使用")

                # 生成密码哈希（使用 bcrypt 或 SHA256+salt）
                password_hash = hash_password(request.password)

                # 创建用户
                user_id = str(uuid.uuid4())
                await cur.execute("""
                    INSERT INTO users (id, username, password_hash, email, nickname, mobile, avatar, dept_id, status, created_at)
                    VALUES (%s, %s, %s, %s, %s, %s, %s, %s, %s, NOW())
                """, (user_id, request.username, password_hash, request.email, request.nickname,
                      request.mobile, request.avatar, request.dept_id, request.status))

                # 分配角色
                if request.role_ids:
                    for role_id in request.role_ids:
                        await cur.execute("""
                            INSERT INTO system_user_role (user_id, role_id)
                            VALUES (%s, %s)
                            ON CONFLICT (user_id, role_id) DO NOTHING
                        """, (user_id, role_id))

                # 分配岗位
                if request.post_ids:
                    for post_id in request.post_ids:
                        await cur.execute("""
                            INSERT INTO system_user_post (user_id, post_id)
                            VALUES (%s, %s)
                            ON CONFLICT (user_id, post_id) DO NOTHING
                        """, (user_id, post_id))

                await conn.commit()

        return {"id": user_id, "message": "用户创建成功"}

    except HTTPException:
        # 重新抛出 HTTP 异常
        raise
    except Exception as e:
        # 记录错误并返回通用错误信息
        logger.error(f"创建用户失败: {str(e)}")
        raise HTTPException(status_code=500, detail="创建用户失败，请稍后重试")


@app.put("/api/v1/system/users/{user_id}")
async def update_user(
    user_id: str,
    request: UpdateUserRequest,
    current_user: Dict = Depends(get_current_user)
):
    """更新用户"""
    if not current_user:
        raise HTTPException(status_code=401, detail="未登录")

    if not await has_permission(current_user['user_id'], 'system:user:update'):
        raise HTTPException(status_code=403, detail="无权限更新用户")

    try:
        async with pool.connection() as conn:
            async with conn.cursor() as cur:
                await cur.execute("SELECT * FROM users WHERE id = %s AND deleted_at IS NULL", (user_id,))
                if not await cur.fetchone():
                    raise HTTPException(status_code=404, detail="用户不存在")

                updates = []
                values = []

                if request.email is not None:
                    updates.append("email = %s")
                    values.append(request.email)
                if request.nickname is not None:
                    updates.append("nickname = %s")
                    values.append(request.nickname)
                if request.mobile is not None:
                    updates.append("mobile = %s")
                    values.append(request.mobile)
                if request.dept_id is not None:
                    updates.append("dept_id = %s")
                    values.append(request.dept_id)
                if request.avatar is not None:
                    updates.append("avatar = %s")
                    values.append(request.avatar)
                if request.status is not None:
                    updates.append("status = %s")
                    values.append(request.status)

                if updates:
                    values.append(user_id)
                    await cur.execute(f"""
                        UPDATE users SET {', '.join(updates)}
                        WHERE id = %s
                    """, values)

                # 更新岗位
                if request.post_ids is not None:
                    await cur.execute("DELETE FROM system_user_post WHERE user_id = %s", (user_id,))
                    for post_id in request.post_ids:
                        await cur.execute("""
                            INSERT INTO system_user_post (user_id, post_id)
                            VALUES (%s, %s)
                        """, (user_id, post_id))

                await conn.commit()

        return {"message": "用户更新成功"}

    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"更新用户失败: {str(e)}")
        raise HTTPException(status_code=500, detail="更新用户失败，请稍后重试")


@app.delete("/api/v1/system/users/{user_id}")
async def delete_user(user_id: str, current_user: Dict = Depends(get_current_user)):
    """删除用户（软删除）"""
    if not current_user:
        raise HTTPException(status_code=401, detail="未登录")

    if not await has_permission(current_user['user_id'], 'system:user:delete'):
        raise HTTPException(status_code=403, detail="无权限删除用户")

    # 不能删除自己
    if user_id == current_user['user_id']:
        raise HTTPException(status_code=400, detail="不能删除自己")

    async with pool.connection() as conn:
        async with conn.cursor() as cur:
            await cur.execute("""
                UPDATE users SET deleted_at = NOW()
                WHERE id = %s
            """, (user_id,))
            await conn.commit()

    return {"message": "用户删除成功"}


@app.put("/api/v1/system/users/{user_id}/roles")
async def assign_user_roles(
    user_id: str,
    request: AssignRoleRequest,
    current_user: Dict = Depends(get_current_user)
):
    """为用户分配角色"""
    if not current_user:
        raise HTTPException(status_code=401, detail="未登录")

    if not await has_permission(current_user['user_id'], 'system:role:assign'):
        raise HTTPException(status_code=403, detail="无权限分配角色")

    async with pool.connection() as conn:
        async with conn.cursor() as cur:
            # 删除现有角色
            await cur.execute("DELETE FROM system_user_role WHERE user_id = %s", (user_id,))

            # 分配新角色
            for role_id in request.role_ids:
                await cur.execute("""
                    INSERT INTO system_user_role (user_id, role_id)
                    VALUES (%s, %s)
                    ON CONFLICT (user_id, role_id) DO NOTHING
                """, (user_id, role_id))

            await conn.commit()

    return {"message": "角色分配成功"}


@app.put("/api/v1/system/users/{user_id}/password")
async def reset_user_password(
    user_id: str,
    new_password: str = Form(...),
    current_user: Dict = Depends(get_current_user)
):
    """重置用户密码"""
    if not current_user:
        raise HTTPException(status_code=401, detail="未登录")

    if not await has_permission(current_user['user_id'], 'system:user:update'):
        raise HTTPException(status_code=403, detail="无权限重置密码")

    password_hash = hash_password(new_password)

    async with pool.connection() as conn:
        async with conn.cursor() as cur:
            await cur.execute("""
                UPDATE users SET password_hash = %s
                WHERE id = %s
            """, (password_hash, user_id))
            await conn.commit()

    return {"message": "密码重置成功"}


# ==================== 角色管理 API ====================

@app.get("/api/v1/system/roles")
async def list_roles(
    page: int = 1,
    page_size: int = 20,
    name: Optional[str] = None,
    status: Optional[int] = None,
    user: Dict = Depends(get_current_user)
):
    """获取角色列表"""
    if not user:
        raise HTTPException(status_code=401, detail="未登录")

    # 验证分页参数
    page, page_size = validate_pagination(page, page_size)

    if not await has_permission(user['user_id'], 'system:role:manage'):
        raise HTTPException(status_code=403, detail="无权限访问")

    async with pool.connection() as conn:
        conditions = ["r.deleted_at IS NULL"]
        params = []

        if name:
            conditions.append("r.name LIKE %s")
            params.append(f"%{name}%")
        if status is not None:
            conditions.append("r.status = %s")
            params.append(status)

        where_clause = " AND ".join(conditions)

        # 获取总数
        async with conn.cursor(row_factory=dict_row) as cur_count:
            await cur_count.execute(f"""
                SELECT COUNT(*) as total FROM system_role r WHERE {where_clause}
            """, params)
            total_result = await cur_count.fetchone()
            total = total_result['total'] if total_result else 0

        # 获取分页数据
        offset = (page - 1) * page_size

        async with conn.cursor(row_factory=dict_row) as cur:
            # 注意: LIMIT/OFFSET 使用字符串插值而不是参数
            await cur.execute(f"""
                SELECT r.*,
                       COUNT(DISTINCT ur.user_id) as user_count
                FROM system_role r
                LEFT JOIN system_user_role ur ON r.id = ur.role_id
                WHERE {where_clause}
                GROUP BY r.id
                ORDER BY r.sort
                LIMIT {page_size} OFFSET {offset}
            """, params)
            roles = await cur.fetchall()

    return {
        "roles": roles,
        "total": total,
        "page": page,
        "page_size": page_size
    }


@app.get("/api/v1/system/roles/all")
async def list_all_roles(user: Dict = Depends(get_current_user)):
    """获取所有角色（不分页，用于下拉选择）"""
