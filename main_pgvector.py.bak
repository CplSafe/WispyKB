# ==================== 菜单管理 API ====================

@app.get("/api/v1/system/menus")
async def list_menus(user: Dict = Depends(get_current_user)):
    """获取菜单列表（树形结构）"""
    if not user:
        raise HTTPException(status_code=401, detail="未登录")

    async with pool.connection() as conn:
        async with conn.cursor(row_factory=dict_row) as cur:
            await cur.execute("""
                SELECT * FROM system_menu
                WHERE deleted_at IS NULL
                ORDER BY sort, id
            """)
            menus = await cur.fetchall()

    def build_tree(parent_id='0'):
        return [
            {
                **m,
                'children': build_tree(m['id'])
            }
            for m in menus
            if m['parent_id'] == parent_id
        ]

    return {"menus": build_tree()}


@app.get("/api/v1/system/menus/flat")
async def list_menus_flat(user: Dict = Depends(get_current_user)):
    """获取菜单列表（扁平结构，用于选择）"""
    if not user:
        raise HTTPException(status_code=401, detail="未登录")

    async with pool.connection() as conn:
        async with conn.cursor(row_factory=dict_row) as cur:
            await cur.execute("""
                SELECT id, name, permission, type, parent_id
                FROM system_menu
                WHERE deleted_at IS NULL
                ORDER BY sort, id
            """)
            menus = await cur.fetchall()

    return {"menus": menus}


@app.get("/api/v1/system/menus/user")
async def get_user_menus(user: Dict = Depends(get_current_user)):
    """获取当前用户的菜单权限"""
    if not user:
        raise HTTPException(status_code=401, detail="未登录")

    # 超级管理员拥有所有菜单
    roles = await get_user_roles(user['user_id'])
    if any(r['code'] == 'super_admin' for r in roles):
        async with pool.connection() as conn:
            async with conn.cursor(row_factory=dict_row) as cur:
                await cur.execute("""
                    SELECT * FROM system_menu
                    WHERE deleted_at IS NULL AND status = 0
                    ORDER BY sort, id
                """)
                menus = await cur.fetchall()
    else:
        async with pool.connection() as conn:
            async with conn.cursor(row_factory=dict_row) as cur:
                await cur.execute("""
                    SELECT DISTINCT m.*
                    FROM system_menu m
                    JOIN system_role_menu rm ON m.id = rm.menu_id
                    JOIN system_user_role ur ON rm.role_id = ur.role_id
                    WHERE ur.user_id = %s
                      AND m.status = 0
                      AND m.deleted_at IS NULL
                      AND m.type IN (1, 2)
                    ORDER BY m.sort, m.id
                """, (user['user_id'],))
                menus = await cur.fetchall()

    def build_tree(parent_id='0'):
        return [
            {
                **m,
                'children': build_tree(m['id'])
            }
            for m in menus
            if m['parent_id'] == parent_id and m['visible']
        ]

    return {"menus": build_tree()}


@app.post("/api/v1/system/menus")
async def create_menu(request: CreateMenuRequest, user: Dict = Depends(get_current_user)):
    """创建菜单"""
    if not user:
        raise HTTPException(status_code=401, detail="未登录")

    if not await has_permission(user['user_id'], 'system:menu:create'):
        raise HTTPException(status_code=403, detail="无权限创建菜单")

    async with pool.connection() as conn:
        async with conn.cursor() as cur:
            # 验证父菜单是否存在
            if request.parent_id != '0':
                await cur.execute("SELECT id FROM system_menu WHERE id = %s AND deleted_at IS NULL", (request.parent_id,))
                if not await cur.fetchone():
                    raise HTTPException(status_code=400, detail="父菜单不存在")

            menu_id = str(uuid.uuid4())
            await cur.execute("""
                INSERT INTO system_menu
                (id, name, permission, type, sort, parent_id, path, icon, component, component_name, status, visible, keep_alive, always_show, created_at)
                VALUES (%s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, NOW())
            """, (menu_id, request.name, request.permission, request.type, request.sort,
                  request.parent_id, request.path, request.icon, request.component,
                  request.component_name, request.status, request.visible,
                  request.keep_alive, request.always_show))
            await conn.commit()

    return {"id": menu_id, "message": "菜单创建成功"}


@app.put("/api/v1/system/menus/{menu_id}")
