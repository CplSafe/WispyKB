@app.get("/api/v1/applications/{app_id}")
async def get_application(app_id: str, user: Dict = Depends(get_current_user)):
    """获取单个应用详情"""
    async with pool.connection() as conn:
        async with conn.cursor(row_factory=dict_row) as cur:
            # 获取用户角色
            await cur.execute("SELECT role FROM users WHERE id = %s", (user['user_id'],))
            user_row = await cur.fetchone()
            user_role = user_row['role'] if user_row else 'user'

            # 超级管理员可以查看所有应用，普通用户只能查看自己的或公开的应用
            if user_role == 'super_admin':
                where_clause = "WHERE a.id = %s"
                where_params = (app_id,)
            else:
                where_clause = "WHERE a.id = %s AND (a.owner_id = %s OR a.is_public = true)"
                where_params = (app_id, user['user_id'])

            await cur.execute(f"""
                SELECT a.id, a.name, a.description, a.model, a.knowledge_base_ids,
                       a.is_public, a.system_prompt, a.welcome_message, a.temperature,
                       a.max_tokens, a.created_at, a.updated_at,
                       u.username as owner_name
                FROM applications a
                LEFT JOIN users u ON a.owner_id = u.id
                {where_clause}
            """, where_params)
            result = await cur.fetchone()

            if not result:
                raise HTTPException(status_code=404, detail="应用不存在或无权限")

            # 转换 knowledge_base_ids 从字符串到数组
            if result.get('knowledge_base_ids'):
                import json
                result['knowledge_base_ids'] = json.loads(result['knowledge_base_ids']) if isinstance(result['knowledge_base_ids'], str) else result['knowledge_base_ids']
            else:
                result['knowledge_base_ids'] = []

            return result


@app.put("/api/v1/applications/{app_id}")
async def update_application(app_id: str, request: CreateApplicationRequest, user: Dict = Depends(get_current_user)):
    """更新应用 - 支持超级管理员编辑所有应用"""
    async with pool.connection() as conn:
        async with conn.cursor(row_factory=dict_row) as cur:
            # 获取用户角色
            await cur.execute("SELECT role FROM users WHERE id = %s", (user['user_id'],))
            user_row = await cur.fetchone()
            user_role = user_row['role'] if user_row else 'user'

            # 超级管理员可以编辑所有应用，普通用户只能编辑自己的应用
            if user_role == 'super_admin':
                where_clause = "WHERE id = %s"
                where_params = (app_id,)
            else:
                where_clause = "WHERE id = %s AND owner_id = %s"
                where_params = (app_id, user['user_id'])

            await cur.execute(f"""
                UPDATE applications
                SET name = %s, description = %s, model = %s, knowledge_base_ids = %s,
                    is_public = %s, system_prompt = %s, welcome_message = %s,
                    share_password = %s, temperature = %s, max_tokens = %s, updated_at = NOW()
                {where_clause}
                RETURNING id
            """, (request.name, request.description, request.model, request.knowledge_base_ids,
                  request.is_public, request.system_prompt, request.welcome_message,
                  request.share_password, request.temperature, request.max_tokens,
                  *where_params))
            result = await cur.fetchone()
            await conn.commit()

            if not result:
                raise HTTPException(status_code=404, detail="应用不存在或无权限")

    return {"message": "应用更新成功"}


# ==================== 公开分享 API ====================

@app.get("/api/v1/share/{share_id}")
async def get_shared_app(share_id: str):
    """获取公开分享的应用信息"""
    async with pool.connection() as conn:
        async with conn.cursor(row_factory=dict_row) as cur:
            await cur.execute("""
                SELECT id, name, description, welcome_message, model, is_public, share_password
                FROM applications WHERE share_id = %s AND is_public = true
            """, (share_id,))
            app = await cur.fetchone()

            if not app:
